# Environment variables template
# Copy this file to .env.local and fill in values for local development
#
# Public variables (EXPO_PUBLIC_) are exposed to client code
# Secret variables should be set in Expo Dashboard for production

# ===== Public Variables (safe to expose) =====
EXPO_PUBLIC_APP_NAME=VSS 2026 Schedule Organizer
EXPO_PUBLIC_VSS_YEAR=2026
EXPO_PUBLIC_VSS_DATES=May 15–19, 2026
EXPO_PUBLIC_VSS_LOCATION=Fort Lauderdale, FL
EXPO_PUBLIC_TOTAL_PRESENTATIONS=1191
EXPO_PUBLIC_GITHUB_REPO=https://github.com/markwgreenlee/vss-2026-scheduler
EXPO_PUBLIC_VSS_WEBSITE=https://www.visionsciences.org

# ===== Secret Variables (keep private) =====
# For production builds, set these in Expo Dashboard, not in .env files
# Examples:
# API_KEY=your-secret-key
# DATABASE_URL=your-database-url
